# Database
DATABASE_URL="postgresql://mediamogul:mediamogul@localhost:5432/mediamogul?schema=public"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers (optional — remove if not using)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Media APIs
TMDB_API_READ_TOKEN=""   # https://www.themoviedb.org/settings/api
IGDB_CLIENT_ID=""        # https://dev.twitch.tv/console (Twitch app — uses IGDB)
IGDB_CLIENT_SECRET=""
# OpenLibrary and MusicBrainz require no keys
