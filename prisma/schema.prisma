generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth required models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  bio           String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  mediaEntries MediaEntry[]
  reviews      Review[]
  lists        MediaList[]
  following    Follow[]     @relation("follower")
  followers    Follow[]     @relation("following")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

enum MediaType {
  MOVIE
  TV_SHOW
  GAME
  BOOK
  MUSIC_ALBUM
  PODCAST
}

enum MediaStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  DROPPED
  ON_HOLD
}

model MediaItem {
  id          String    @id @default(cuid())
  mediaType   MediaType
  title       String
  description String?   @db.Text
  coverImage  String?
  releaseDate DateTime?

  // External API IDs
  tmdbId    String? // TMDB (movies & TV)
  igdbId    String? // IGDB (games)
  openLibId String? // OpenLibrary (books)
  mbId      String? // MusicBrainz (music)

  // Type-specific metadata (genres, cast, platforms, etc.)
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries   MediaEntry[]
  reviews   Review[]
  listItems ListItem[]

  @@unique([tmdbId, mediaType])
  @@unique([igdbId, mediaType])
  @@index([mediaType])
  @@index([title])
}

model MediaEntry {
  id          String      @id @default(cuid())
  userId      String
  mediaItemId String
  status      MediaStatus
  rating      Float? // 0–10
  progress    Int? // episodes watched, pages read, hours played, etc.
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?     @db.Text
  isFavorite  Boolean     @default(false)
  isPrivate   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaItemId])
}

model Review {
  id               String  @id @default(cuid())
  userId           String
  mediaItemId      String
  title            String?
  content          String  @db.Text
  rating           Float? // 0–10
  containsSpoilers Boolean @default(false)
  isPrivate        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
}

model MediaList {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String? @db.Text
  isPrivate   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ListItem[]
}

model ListItem {
  id          String  @id @default(cuid())
  listId      String
  mediaItemId String
  position    Int
  notes       String?

  createdAt DateTime @default(now())

  list      MediaList @relation(fields: [listId], references: [id], onDelete: Cascade)
  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([listId, mediaItemId])
  @@unique([listId, position])
}
